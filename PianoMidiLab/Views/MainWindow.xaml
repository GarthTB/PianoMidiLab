<Window x:Class="PianoMidiLab.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:PianoMidiLab.VMs"
    Title="PianoMidiLab 1.0.0"
    FontSize="14"
    AllowDrop="True"
    UseLayoutRounding="True"
    ResizeMode="CanMinimize"
    SizeToContent="WidthAndHeight">
    <Window.DataContext>
        <vm:MainVM/>
    </Window.DataContext>
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background"
                Value="#EAEAEA"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Padding"
                Value="12,4"/>
        </Style>
    </Window.Resources>
    <TabControl Padding="0">
        <TabItem Header="文件">
            <Grid Height="240"
                Width="480"/>
        </TabItem>
    </TabControl>
</Window>